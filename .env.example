# Copy this file to .env and set your PostgreSQL password:
# JWT_SECRET=your-secret-key  # Optional, for staff login. Change in production.
# cp .env.example .env
# Then edit .env and replace YOUR_PASSWORD with your actual password.

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres

# Google Calendar API (optional). For push webhook, use a public URL (e.g. ngrok in dev).
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./path/to/service-account.json
# GOOGLE_CALENDAR_ID=primary
# CALENDAR_WEBHOOK_BASE_URL=https://your-public-url.example.com

# Admin Sheet sync: fetch MonthlySchedule from Google Sheets into DB. Share spreadsheet with service account.
# GOOGLE_ADMIN_SHEET_ID=1upKC-iNWs7HIeKiVVAegve5O5WbNebbjMlveMcvnuow

# Calendar Polling / Backfill: GAS Webhook for MonthlySchedule. Same key as calendarAPI Config.js POLL_API_KEY.
# Set here (project root) for server-side backfill — no client rebuild needed.
# CALENDAR_POLL_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
# CALENDAR_POLL_API_KEY=your_poll_api_key

# Client polling (optional): copy these to client/.env with VITE_ prefix so the React app can poll GAS in dev.
# VITE_CALENDAR_POLL_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
# VITE_CALENDAR_POLL_API_KEY=your_poll_api_key
# Production (PM2): set CALENDAR_POLL_* above only — the SPA loads them from /api/config/calendar-poll after login (no client rebuild).
