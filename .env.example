# Copy this file to .env and set your PostgreSQL password:
# JWT_SECRET=your-secret-key  # Optional, for staff login. Change in production.
# cp .env.example .env
# Then edit .env and replace YOUR_PASSWORD with your actual password.

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres

# Google Calendar API (optional). For push webhook, use a public URL (e.g. ngrok in dev).
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./path/to/service-account.json
# GOOGLE_CALENDAR_ID=primary
# CALENDAR_WEBHOOK_BASE_URL=https://your-public-url.example.com

# Admin Sheet sync: fetch MonthlySchedule from Google Sheets into DB. Share spreadsheet with service account.
# GOOGLE_ADMIN_SHEET_ID=1upKC-iNWs7HIeKiVVAegve5O5WbNebbjMlveMcvnuow

# Calendar Polling / Backfill: GAS Webhook for MonthlySchedule. Same key as calendarAPI Config.js POLL_API_KEY.
# Set here (project root) for server-side backfill — no client rebuild needed.
# CALENDAR_POLL_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
# CALENDAR_POLL_API_KEY=your_poll_api_key
#
# Server-side full sync from GAS → PostgreSQL on a schedule (no browser). Requires CALENDAR_POLL_* above.
# Omit or set to 0/off to disable. Example: every 2 minutes (cron 5-field).
# CALENDAR_POLL_SERVER_CRON=*/2 * * * *
# CALENDAR_POLL_SERVER_CRON_TZ=Asia/Tokyo

# Client polling (optional): copy these to client/.env with VITE_ prefix so the React app can poll GAS in dev.
# VITE_CALENDAR_POLL_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
# VITE_CALENDAR_POLL_API_KEY=your_poll_api_key
# Production (PM2): set CALENDAR_POLL_* above only — the SPA loads them from /api/config/calendar-poll after login (no client rebuild).

# Google Contacts (optional). Creates/updates a People API contact when a student is saved.
# Requires Google Workspace + domain-wide delegation for the service account with scope:
#   https://www.googleapis.com/auth/contacts
# GOOGLE_CONTACTS_ENABLED=1
# GOOGLE_CONTACTS_DELEGATED_USER=office@yourdomain.com

# Student -> GAS contact sync (optional): after POST/PUT /api/students, server sends student payload to GAS doPost.
# Keep this key separate from CALENDAR_POLL_API_KEY.
# STUDENT_SYNC_GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
# STUDENT_SYNC_API_KEY=your_student_sync_api_key
# Optional: default 30000 ms (GAS cold start). Max 120000.
# STUDENT_SYNC_TIMEOUT_MS=45000

# Owner's course (payment contains "owner"): only book when this staff member is on shift (matches staff.name to teacher_schedules.teacher_name).
# OWNER_COURSE_STAFF_ID=1

# Lesson booking -> GAS Calendar create (required if you use in-app booking).
# This creates a real Calendar event so it persists across refresh and is not deleted by poll reconcile.
# BOOKING_GAS_URL can usually be the same as CALENDAR_POLL_URL (same Apps Script web app).
# BOOKING_GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
# BOOKING_API_KEY=your_booking_api_key
# Optional: default 30000 ms. Max 120000.
# BOOKING_SYNC_TIMEOUT_MS=45000
