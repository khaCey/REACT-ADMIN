# Copy this file to .env and set your PostgreSQL password:
# JWT_SECRET=your-secret-key  # Optional, for staff login. Change in production.
# cp .env.example .env
# Then edit .env and replace YOUR_PASSWORD with your actual password.

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres

# Google Calendar API (optional). For push webhook, use a public URL (e.g. ngrok in dev).
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./path/to/service-account.json
# GOOGLE_CALENDAR_ID=primary
# CALENDAR_WEBHOOK_BASE_URL=https://your-public-url.example.com

# Calendar Polling (optional). Poll GAS Webhook for MonthlySchedule updates. See POLLING_API_SPEC.md.
# Set in client/.env for Vite (VITE_*). Same key as calendarAPI Config.js POLL_API_KEY.
# VITE_CALENDAR_POLL_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
# VITE_CALENDAR_POLL_API_KEY=your_poll_api_key
