# Copy to .env — required for calendar polling (Dashboard / MonthlySchedule sync from GAS).
# Same URL and key as CALENDAR_POLL_* in project root .env; must use VITE_ prefix for Vite to expose to the client.
# VITE_CALENDAR_POLL_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
# VITE_CALENDAR_POLL_API_KEY=your_poll_api_key
# Optional: poll interval in ms (min 10000). Default 120000 (2 min). Production can use root CALENDAR_POLL_* only; rebuild client if you set this.
# VITE_CALENDAR_POLL_INTERVAL_MS=120000
# VITE_CALENDAR_POLL_INTERVAL_MS=60000
